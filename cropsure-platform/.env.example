# DATABASE
POSTGRES_USER=cropsure
POSTGRES_PASSWORD=cropsure_dev_password
POSTGRES_DB=cropsure_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://cropsure:cropsure_dev_password@postgres:5432/cropsure_db

# INTERNAL SERVICES
ML_SERVICE_URL=http://ml-service:8001
BACKEND_URL=http://backend:8000
FRONTEND_URL=http://localhost:5173

# APP SETTINGS
APP_ENV=development
SECRET_KEY=change_this_in_production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# BUSINESS LOGIC
