RISK_MULTIPLIER_MEDIUM=1.2
RISK_MULTIPLIER_HIGH=1.8
NDVI_STRESS_THRESHOLD=0.25
NDVI_CATASTROPHIC_THRESHOLD=0.50
NDVI_CONSECUTIVE_READINGS=2
MONITORING_INTERVAL_DAYS=5
