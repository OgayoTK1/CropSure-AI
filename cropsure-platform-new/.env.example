# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cropsure:cropsure@localhost:5432/cropsure

# ── ML Service ────────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8001

# ── Sentinel Hub (free account at sentinelhub.com) ───────────────────────────
# Leave empty to use built-in simulation (works for demo without credentials)
# SENTINEL HUB
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_ACCOUNT_ID=
SENTINEL_HUB_BASE_URL=https://services.sentinel-hub.com
# ── M-Pesa Daraja (developer.safaricom.co.ke — use sandbox for dev) ───────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=
# Set via ngrok: ngrok http 8000 → use the https URL here
MPESA_CALLBACK_URL=https://YOUR_NGROK_URL/mpesa/stk-callback
MPESA_B2C_RESULT_URL=https://YOUR_NGROK_URL/mpesa/b2c-callback
MPESA_B2C_TIMEOUT_URL=https://YOUR_NGROK_URL/mpesa/b2c-timeout
MPESA_SANDBOX=true

# ── Africa's Talking SMS (account.africastalking.com) ─────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=CropSure
AT_USSD_CODE=*384#
# Set via ngrok: ngrok http 8000 → use the https URL here
AT_USSD_CALLBACK_URL=https://YOUR_NGROK_URL/ussd/callback

# ── Twilio WhatsApp (console.twilio.com) ─────────────────────────────────────
# TWILIO WHATSAPP
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
DEBUG=true
PREMIUM_PER_ACRE_KES=300
COVERAGE_MULTIPLIER=8
