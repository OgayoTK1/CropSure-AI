# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cropsure
# SQLite (local dev fallback — no extra setup needed)
# DATABASE_URL=sqlite+aiosqlite:///./cropsure.db

# ── ML Microservice ───────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8001

# ── M-Pesa Daraja ─────────────────────────────────────────────────────────────
MPESA_ENVIRONMENT=sandbox                          # sandbox | production
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379                             # Daraja sandbox shortcode
MPESA_PASSKEY=your_passkey

# B2C (payouts)
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=your_security_credential

# Callback URLs (must be publicly reachable — use ngrok in dev)
MPESA_CALLBACK_URL=https://your-domain.com/mpesa/stk-callback
MPESA_B2C_RESULT_URL=https://your-domain.com/mpesa/b2c-callback
MPESA_B2C_TIMEOUT_URL=https://your-domain.com/mpesa/b2c-timeout

# ── Africa's Talking (SMS) ────────────────────────────────────────────────────
AT_API_KEY=your_at_api_key
AT_USERNAME=sandbox                                # use your username in production

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886         # Twilio sandbox number

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for development.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Drought thresholds (optional overrides) ───────────────────────────────────
# These live in trigger.py; override here if needed via env
# NDVI_DROUGHT_THRESHOLD=0.35
# RAINFALL_DROUGHT_MM=50.0
